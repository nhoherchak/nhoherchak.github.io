<script>
document.querySelectorAll('[data-carousel]').forEach(carousel => {
  const images = JSON.parse(carousel.querySelector('[data-carousel-images]').textContent);
  const img = carousel.querySelector('[data-carousel-img]');
  const scrollContainer = carousel.querySelector('[data-carousel-scroll]');
  const dotsContainer = carousel.querySelector('[data-carousel-dots]');
  let current = 0;

  // Build dots
  images.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'w-2 h-2 rounded-full transition-colors ' + (i === 0 ? 'bg-gray-900' : 'bg-gray-300');
    dot.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(dot);
  });

  function applyLayout() {
    if (img.naturalWidth < 800) {
      // Narrow / phone mockup — centered, taller frame
      scrollContainer.style.height = '700px';
      img.style.width = '50%';
      img.style.margin = '0 auto';
      img.style.display = 'block';
    } else {
      // Wide / desktop mockup — full width
      scrollContainer.style.height = '500px';
      img.style.width = '100%';
      img.style.margin = '';
      img.style.display = '';
    }
  }

  img.addEventListener('load', applyLayout);

  function goTo(index) {
    current = (index + images.length) % images.length;
    img.src = images[current];
    scrollContainer.scrollTop = 0;
    dotsContainer.querySelectorAll('button').forEach((dot, i) => {
      dot.className = 'w-2 h-2 rounded-full transition-colors ' + (i === current ? 'bg-gray-900' : 'bg-gray-300');
    });
  }

  // Apply layout for the initial image
  if (img.complete) applyLayout();

  carousel.querySelector('[data-carousel-prev]').addEventListener('click', () => goTo(current - 1));
  carousel.querySelector('[data-carousel-next]').addEventListener('click', () => goTo(current + 1));
});
</script>
